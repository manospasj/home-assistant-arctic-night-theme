          "sections": [
            {
              "type": "grid",
              "cards": [
                {
                  "type": "heading",
                  "heading": "Welcome",
                  "heading_style": "title",
                  "icon": "mdi:hand-wave"
                },
                {
                  "type": "markdown",
                  "content": "## Arctic Night Theme\nWelcome to the **Arctic Night** theme demo. This dashboard showcases all major Home Assistant card types styled with the theme.\n\nUse the tabs above to explore climate controls, lights, media, devices, and data views."
                },
                {
                  "type": "glance",
                  "title": "Quick Overview",
                  "entities": [
                    {
                      "entity": "sensor.living_room_temperature",
                      "name": "Living Room"
                    },
                    {
                      "entity": "sensor.bedroom_temperature",
                      "name": "Bedroom"
                    },
                    {
                      "entity": "weather.demo_weather_south",
                      "name": "Weather"
                    },
                    {
                      "entity": "light.ceiling_lights",
                      "name": "Ceiling"
                    },
                    {
                      "entity": "climate.heatpump",
                      "name": "Heat Pump"
                    }
                  ]
                }
              ]
            },
            {
              "type": "grid",
              "cards": [
                {
                  "type": "heading",
                  "heading": "Weather",
